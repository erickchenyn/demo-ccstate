{
    "semi": false,
    "singleQuote": true,
    "printWidth": 80,
    "tabWidth": 4,
    "useTabs": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "plugins": ["@ianvs/prettier-plugin-sort-imports"],
    "importOrder": [
        "^react",
        "^@?\\w",
        "^[./]"
    ],
    "overrides": [
        {
            "files": "*.md",
            "options": {
                "tabWidth": 2,
                "proseWrap": "preserve"
            }
        }
    ]
}
